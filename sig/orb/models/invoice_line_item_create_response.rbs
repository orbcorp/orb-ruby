        def self?.variants: -> ::Array[Orb::Models::InvoiceLineItemCreateResponse::adjustment]
      end

      type sub_line_item =
        Orb::MatrixSubLineItem | Orb::TierSubLineItem | Orb::OtherSubLineItem

      module SubLineItem
        extend Orb::Internal::Type::Union

